<% layout('/layouts/boilerplate') %>
<div class="row">
    <div class="col-8 offset-2">
<body>
    <br> <br> <br>
    <h3> Add New listing</h3>
    <form method="POST" action="/listings">
        <div>
            <label for="title" class="form-label">Title</label>
            <input name=listing[title] placeholder="Enter title of the property" type="text" class="form-control"/>
        </div>
       
        <div>
            <label for="description" class="form-label">Description</label>
            <textarea name=listing[description] placeholder="Enter description for the property" class="form-control" type="text"></textarea> 
        </div>

        <div>
            <label for="image" class="form-label">Enter URL</label>
            <input name=listing[image] placeholder="Enter URL for property image" class="form-control" type="text"/>
        </div>
        <div class="row">
            <div class="mb-3 col-md-4">
                <label for="price" class="form-label">Price Per Night</label>
                <input name=listing[price] placeholder="Enter price per night for property " class="form-control" type="number"/>
            </div>
    
           
            <div class="mb-3 col-md-8">
                <label for="location" class="form-label">Location</label>
                <input name=listing[location] placeholder="Enter location of the property" class="form-control" type="text"/>
            </div>
        </div>
       

       
        <div>
            <label for="country" class="form-label">Country</label>
            <input name=listing[country] placeholder="Enter country of the property" class="form-control" type="text"/>

        </div>

        <br><br>
        <button class="btn btn-dark btn-add" type="submit">
            ADD
        </button>
    </form>
    <br>

    <!-- <form method="GET" action="/listings">
        <button>
            Go To Home Page
        </button>
    </form> -->
</body>
<br> <br> <br>
</div>
</div>