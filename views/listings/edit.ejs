<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit This Listing</title>
</head>
<body>
    <form method="POST" action="/listings/<%=listing._id%>?_method=PUT">
        <input name=listing[title] type="text" value="<%=listing.title%>"/>
        <br><br>
        <textarea cols="30" rows="5" name=listing[description] type="text" ><%=listing.description%></textarea>
        <br><br>
        <input name=listing[image] value="<%=listing.image%>" type="text"/>
        <br><br>
        <input name=listing[price] value="<%=listing.price%>" type="number"/>
        <br><br>
        <input name=listing[location] value="<%=listing.location%>" type="text"/>
        <br><br>
        <input name=listing[country] value="<%=listing.country%>" type="text"/>
        <br><br>
        <button type="submit">
            EDIT
        </button>
    </form>
    <br>

    <form method="GET" action="/listings">
        <button>
            Go To Home Page
        </button>
    </form>
</body>
</html>